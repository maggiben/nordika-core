# HTTP server port (optional; defaults to 3000)
PORT=3000

# MongoDB connection (MONGO_URI takes precedence over MONGO_URL)
MONGO_URI=mongodb://localhost:27017/nodika
MONGO_URL=mongodb://localhost:27017/nodika

# Redis cache (optional; caching is disabled when omitted)
REDIS_URL=redis://localhost:6379

# Shared HS256 secret for issuing and validating access JWTs
JWT_SECRET=replace-with-a-long-random-secret

# Public BFF URL used in email action links
APP_URL=http://localhost:3000
# Resend (https://resend.com) API key and verified sender
RESEND_API_KEY=re_replace_with_a_resend_api_key
RESEND_FROM=Nodika <auth@example.com>

# Evolution API WhatsApp gateway (optional; omit all three to disable sending)
EVOLUTION_API_URL=https://your-evolution-host.example
EVOLUTION_API_KEY=replace-with-evolution-api-key
EVOLUTION_INSTANCE=your-whatsapp-instance-name
# Optional shared secret for POST /messaging/webhooks/evolution (header x-webhook-secret)
EVOLUTION_WEBHOOK_SECRET=

# Weekly status cron (optional; default Mondays 09:00 America/Argentina/Buenos_Aires)
WHATSAPP_WEEKLY_CRON=0 9 * * 1
WHATSAPP_TIMEZONE=America/Argentina/Buenos_Aires
# Default WhatsApp message language when a contact has none set (es|en)
WHATSAPP_DEFAULT_LANGUAGE=es
