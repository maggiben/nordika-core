{
  "templates": {
    "weekly_status": {
      "name": "Consulta semanal de avance",
      "description": "Mensaje semanal para consultar porcentaje, duración y avance.",
      "title": "{{ciclo_name}}",
      "text": "Ciclo {{ciclo_inicio}} → {{ciclo_fin}}\nSemana {{week}}: {{percent}}%\nDuración: {{duration}}\nAvance: {{avance}}\nNotas: {{notes}}",
      "footer": "Nodika",
      "widgets": [
        {
          "type": "button",
          "id": "ack",
          "label": "Recibido"
        },
        {
          "type": "input",
          "id": "comentario",
          "label": "Comentario",
          "placeholder": "Opcional"
        },
        {
          "type": "checkbox",
          "id": "bloqueos",
          "label": "¿Hay bloqueos?",
          "options": [
            { "id": "si", "label": "Sí" },
            { "id": "no", "label": "No" }
          ]
        }
      ]
    }
  },
  "prompts": {
    "inputReply": "Responde con el texto para \"{{id}}\".",
    "checkboxOption": "{{label}} → responde \"{{id}}\"",
    "buttonReply": "Responde \"{{id}}\" para \"{{label}}\"."
  }
}
